-- Функция обновления позиции настроек (СЛЕВА)
local function UpdateSettingsPosition()
    if not isScriptActive then return end
    local mainX = mainFrame.Position.X.Offset
    local mainY = mainFrame.Position.Y.Offset
    settingsFrame.Position = UDim2.new(0, mainX - 10 - 250, 0, mainY)
end

-- Функции биндов
local function StartBind(type)
    waitingForBind = true
    bindType = type
    if type == "ESP" then
        bindESPButton.Text = "..."
    elseif type == "Hide" then
        bindHideButton.Text = "..."
    end
end

local function SetBind(key)
    waitingForBind = false
    if bindType == "ESP" then
        bindESP = key
        bindESPButton.Text = "Назначить"
        bindESPLabel.Text = "Bind ESP: " .. key.Name
    elseif bindType == "Hide" then
        bindHide = key
        bindHideButton.Text = "Назначить"
        bindHideLabel.Text = "Bind Hide: " .. key.Name
    end
    bindType = nil
end

-- НАЗНАЧЕНИЕ БИНДОВ
bindESPButton.MouseButton1Click:Connect(function()
    if not isScriptActive then return end
    StartBind("ESP")
end)

bindHideButton.MouseButton1Click:Connect(function()
    if not isScriptActive then return end
    StartBind("Hide")
end)

-- ОБРАБОТЧИК КЛАВИШ
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if waitingForBind and input.UserInputType == Enum.UserInputType.Keyboard then
        SetBind(input.KeyCode)
        return
    end
    if bindESP and input.KeyCode == bindESP then
        espEnabled = not espEnabled
        toggleButton.Text = espEnabled and "✅ ESP ВКЛ" or "❌ ESP ВЫКЛ"
        toggleButton.BackgroundColor3 = espEnabled and Color3.fromRGB(60, 200, 80) or Color3.fromRGB(200, 60, 60)
        for player, objects in pairs(espObjects) do
            local isSelf = (player == LocalPlayer)
            local visible = espEnabled and ((isSelf and showSelf) or (not isSelf and showOthers))
            if objects.Highlight then objects.Highlight.Enabled = visible end
            if objects.Billboard then objects.Billboard.Enabled = visible and showNames end
        end
    end
    if bindHide and input.KeyCode == bindHide then
        toggleCollapse()
    end
end)

local function UpdateColorDisplay()
    if not isScriptActive then return end
    if rgbMode then
        colorDisplayLabel.Text = "🌈 RGB Режим"
        colorDisplayLabel.BackgroundColor3 = Color3.fromRGB(200, 100, 255)
        colorDisplayLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        return
    end
    
    local colorName = "Белый"
    if CurrentColor == Color3.fromRGB(255, 0, 0) then colorName = "Красный"
    elseif CurrentColor == Color3.fromRGB(0, 255, 0) then colorName = "Зелёный"
    elseif CurrentColor == Color3.fromRGB(0, 0, 255) then colorName = "Синий"
    elseif CurrentColor == Color3.fromRGB(255, 255, 0) then colorName = "Жёлтый"
    elseif CurrentColor == Color3.fromRGB(255, 0, 255) then colorName = "Пурпурный"
    elseif CurrentColor == Color3.fromRGB(0, 255, 255) then colorName = "Голубой"
    elseif CurrentColor == Color3.fromRGB(255, 255, 255) then colorName = "Белый"
    elseif CurrentColor == Color3.fromRGB(0, 0, 0) then colorName = "Чёрный"
    else
        local r = math.round(CurrentColor.R * 255)
        local g = math.round(CurrentColor.G * 255)
        local b = math.round(CurrentColor.B * 255)
        colorName = string.format("RGB(%d, %d, %d)", r, g, b)
    end
    
    colorDisplayLabel.Text = colorName
    colorDisplayLabel.BackgroundColor3 = CurrentColor
    colorDisplayLabel.TextColor3 = (CurrentColor.R < 0.5 and CurrentColor.G < 0.5 and CurrentColor.B < 0.5) and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(0, 0, 0)
end

local function ResetColorToWhite()
    if not isScriptActive or rgbMode then return end
    CurrentColor = Color3.fromRGB(255, 255, 255)
    Cursor.Position = UDim2.new(0, -5, 0, -5)
    SliderCursor.Position = UDim2.new(-0.25, 0, 0, -4)
    UpdateColorDisplay()
    updateESPColor()
end

local function GetColorFromPosition(X, Y, SizeX, SizeY)
    return Color3.fromHSV(X / SizeX, 1, 1 - (Y / SizeY))
end

local function UpdateColor(Input)
    if not isScriptActive or rgbMode then return end
    local Position = Input.Position
    local AbsolutePosition = ColorpickerMain.AbsolutePosition
    local Size = ColorpickerMain.AbsoluteSize
    local X = math.clamp(Position.X - AbsolutePosition.X, 0, Size.X)
    local Y = math.clamp(Position.Y - AbsolutePosition.Y, 0, Size.Y)
    Cursor.Position = UDim2.new(0, X - 5, 0, Y - 5)
    CurrentColor = GetColorFromPosition(X, Y, Size.X, Size.Y)
    UpdateColorDisplay()
    updateESPColor()
end

local function UpdateSlider(Input)
    if not isScriptActive or rgbMode then return end
    local Position = Input.Position
    local AbsolutePosition = BrightnessSlider.AbsolutePosition
    local Size = BrightnessSlider.AbsoluteSize
    local Y = math.clamp(Position.Y - AbsolutePosition.Y, 0, Size.Y)
    SliderCursor.Position = UDim2.new(-0.25, 0, 0, Y - 4)
    local H, S, V = CurrentColor:ToHSV()
    CurrentColor = Color3.fromHSV(H, S, 1 - (Y / Size.Y))
    UpdateColorDisplay()
    updateESPColor()
end

local function UpdateRGBColors()
    if not isScriptActive or not rgbMode then return end
    local color = Color3.fromHSV(tick() % 1, 1, 1)
    for player, objects in pairs(espObjects) do
        if objects.Highlight then
            objects.Highlight.OutlineColor = color
            objects.Highlight.FillColor = color
        end
        if objects.NameLabel and player ~= LocalPlayer then
            objects.NameLabel.TextColor3 = color
        end
    end
end

local function ToggleRGBMode()
    if not isScriptActive then return end
    rgbMode = not rgbMode
    if rgbMode then
        rgbToggle.Text = "🌈 RGB РЕЖИМ ВКЛ"
        rgbToggle.BackgroundColor3 = Color3.fromRGB(200, 50, 100)
        colorDisplayLabel.Text = "🌈 RGB Режим"
        colorDisplayLabel.BackgroundColor3 = Color3.fromRGB(200, 100, 255)
        colorDisplayLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        if rgbConnection then rgbConnection:Disconnect() end
        rgbConnection = RunService.RenderStepped:Connect(UpdateRGBColors)
    else
        rgbToggle.Text = "🌈 RGB РЕЖИМ ВЫКЛ"
        rgbToggle.BackgroundColor3 = Color3.fromRGB(100, 50, 200)
        if rgbConnection then
            rgbConnection:Disconnect()
            rgbConnection = nil
        end
        UpdateColorDisplay()
        updateESPColor()
    end
end

