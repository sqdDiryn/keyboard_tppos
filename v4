function createESP(player)
    if not isScriptActive or playersProcessing[player] then return end
    playersProcessing[player] = true
    local character = player.Character
    if not character then playersProcessing[player] = nil return end
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then playersProcessing[player] = nil return end
    
    removeESP(player)
    
    local color = rgbMode and Color3.fromHSV(tick() % 1, 1, 1) or CurrentColor
    
    local highlight = Instance.new("Highlight")
    highlight.Parent = character
    highlight.FillColor = color
    highlight.FillTransparency = 1
    highlight.OutlineColor = color
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    
    local billboard = Instance.new("BillboardGui")
    billboard.Parent = humanoidRootPart
    billboard.Size = UDim2.new(0, 200, 0, 40)
    billboard.Adornee = humanoidRootPart
    billboard.AlwaysOnTop = true
    billboard.StudsOffset = Vector3.new(0, 3.5, 0)
    
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Parent = billboard
    nameLabel.Size = UDim2.new(1, 0, 1, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = player.Name
    nameLabel.TextColor3 = color
    nameLabel.TextSize = 14
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    nameLabel.TextStrokeTransparency = 0.3
    
    if player == LocalPlayer then
        nameLabel.Text = player.Name .. " (ВЫ)"
        nameLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
    end
    
    espObjects[player] = {Highlight = highlight, Billboard = billboard, NameLabel = nameLabel}
    updateVisibility(player)
    playersProcessing[player] = nil
end

function updateVisibility(player)
    if not isScriptActive then return end
    local objects = espObjects[player]
    if not objects then return end
    local isSelf = (player == LocalPlayer)
    local visible = espEnabled and ((isSelf and showSelf) or (not isSelf and showOthers))
    if objects.Highlight then objects.Highlight.Enabled = visible end
    if objects.Billboard then objects.Billboard.Enabled = visible and showNames end
end

function removeESP(player)
    if espObjects[player] then
        if espObjects[player].Highlight then espObjects[player].Highlight:Destroy() end
        if espObjects[player].Billboard then espObjects[player].Billboard:Destroy() end
        espObjects[player] = nil
    end
    playersProcessing[player] = nil
end

function updateAllVisibility()
    if not isScriptActive then return end
    for player, _ in pairs(espObjects) do
        updateVisibility(player)
    end
end

function updateAllNames()
    if not isScriptActive then return end
    for player, objects in pairs(espObjects) do
        if objects.Billboard then
            local isSelf = (player == LocalPlayer)
            local visible = espEnabled and ((isSelf and showSelf) or (not isSelf and showOthers))
            objects.Billboard.Enabled = visible and showNames
        end
    end
end

