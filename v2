-- Переключение меню
function toggleMenu()
    isMenuOpen = not isMenuOpen
    if screenGui then
        screenGui.Enabled = isMenuOpen
        if not isMenuOpen then
            isSettingsOpen = false
            if settingsFrame then
                settingsFrame.Visible = false
            end
        end
    else
        createGUI()
        isMenuOpen = true
    end
end

-- Переключение настроек
function toggleSettings()
    isSettingsOpen = not isSettingsOpen
    if settingsFrame then
        settingsFrame.Visible = isSettingsOpen
        -- Скрываем/показываем список локаций
        local scrollFrame = mainFrame:FindFirstChild("ScrollFrame")
        local controlFrame = mainFrame:FindFirstChild("ControlFrame")
        local infoLabel = mainFrame:FindFirstChild("InfoLabel")
        
        if scrollFrame and controlFrame and infoLabel then
            scrollFrame.Visible = not isSettingsOpen
            controlFrame.Visible = not isSettingsOpen
            infoLabel.Visible = not isSettingsOpen
        end
    end
end

-- Выбор локации
function selectLocation(name, coords)
    selectedLocation = {name = name, x = coords[1], y = coords[2], z = coords[3]}
    
    local infoLabel = mainFrame:FindFirstChild("InfoLabel")
    if infoLabel then
        infoLabel.Text = "✅ Выбрано: " .. name .. " (" .. coords[1] .. ", " .. coords[2] .. ", " .. coords[3] .. ")"
        infoLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
    end
    
    print("📍 Selected: " .. name .. " - " .. coords[1] .. ", " .. coords[2] .. ", " .. coords[3])
end

-- Функция телепортации
local function teleportTo(x, y, z)
    local player = game.Players.LocalPlayer
    if not player or not player.Character then
        return false
    end
    
    local hrp = player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then
        return false
    end
    
    hrp.CFrame = CFrame.new(x, y, z)
    return true
end

-- Анти-АФК (движение камеры или клик)
local function doAntiAFK()
    if not settings.antiAFK then return end
    
    local player = game.Players.LocalPlayer
    if player and player.Character and player.Character:FindFirstChild("Humanoid") then
        -- Делаем небольшой прыжок для анти-АФК
        local humanoid = player.Character:FindFirstChild("Humanoid")
        if humanoid and humanoid:GetState() ~= Enum.HumanoidStateType.Jumping then
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        end
    end
end

-- Запуск фарма
function startFarming()
    if isRunning then
        print("⚠️ Farming already running!")
        return
    end
    
    if not selectedLocation then
        print("⚠️ Please select a location first!")
        local infoLabel = mainFrame:FindFirstChild("InfoLabel")
        if infoLabel then
            infoLabel.Text = "⚠️ Сначала выберите локацию!"
            infoLabel.TextColor3 = Color3.fromRGB(255, 100, 0)
        end
        return
    end
    
    isRunning = true
    isWaiting = false
    currentCycle = 0
    lastTick = tick()
    
    local statusLabel = mainFrame:FindFirstChild("StatusLabel")
    if statusLabel then
        statusLabel.Text = "Статус: 🔄 Работает"
        statusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
    end
    
    print("=====================================")
    print("🚀 STARTING FARM - KeyboardByIshaki V1")
    print("📍 Location: " .. selectedLocation.name)
    print("📍 Coords: " .. selectedLocation.x .. ", " .. selectedLocation.y .. ", " .. selectedLocation.z)
    print("⏱ Interval: " .. settings.interval .. "s")
    print("🛡 Anti-AFK: " .. (settings.antiAFK and "ON" or "OFF"))
    print("=====================================")
    
    -- Первая телепортация
    teleportTo(selectedLocation.x, selectedLocation.y, selectedLocation.z)
    
    if connection then
        connection:Disconnect()
    end
    
    local antiAFKCounter = 0
    
    connection = game:GetService("RunService").Heartbeat:Connect(function()
        if not isRunning then
            return
        end
        
        if isWaiting then
            if tick() - waitStart >= settings.waitAfterCycle then
                isWaiting = false
                print("✅ Wait finished! Continuing...")
                teleportTo(selectedLocation.x, selectedLocation.y, selectedLocation.z)
            end
            return
        end
        
        if tick() - lastTick >= settings.interval then
            lastTick = tick()
            teleportTo(selectedLocation.x, selectedLocation.y, selectedLocation.z)
            currentCycle = currentCycle + 1
            
            -- Анти-АФК каждые 5 циклов
            antiAFKCounter = antiAFKCounter + 1
            if antiAFKCounter >= 5 then
                antiAFKCounter = 0
                doAntiAFK()
            end
            
            if currentCycle % 10 == 0 then
                print("🔄 Cycle #" .. currentCycle .. " - Teleported to " .. selectedLocation.name)
            end
        end
    end)
end

-- Остановка фарма
function stopFarming()
    if not isRunning then
        print("⚠️ Farming not running!")
        return
    end
    
    isRunning = false
    isWaiting = false
    
    if connection then
        connection:Disconnect()
        connection = nil
    end
    
    local statusLabel = mainFrame:FindFirstChild("StatusLabel")
    if statusLabel then
        statusLabel.Text = "Статус: ⏹ Остановлен"
        statusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    end
    
    print("=====================================")
    print("⏹ FARM STOPPED - KeyboardByIshaki V1")
    print("Total cycles: " .. currentCycle)
    print("=====================================")
end

