local noclipConnection = nil

-- Функция для применения Noclip ко всем частям персонажа
local function applyNoclip()
    if not Character then return end
    
    for _, part in ipairs(Character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = false
        end
    end
end

-- Функция для отключения Noclip
local function removeNoclip()
    if not Character then return end
    
    for _, part in ipairs(Character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = true
        end
    end
end

-- Запуск постоянного цикла Noclip
local function startNoclipLoop()
    -- Останавливаем предыдущий цикл, если он был
    if noclipConnection then
        noclipConnection:Disconnect()
        noclipConnection = nil
    end
    
    -- Запускаем постоянный цикл обновления Noclip
    noclipConnection = RunService.Heartbeat:Connect(function()
        if noclipEnabled and Character and Character.Parent then
            applyNoclip()
        end
    end)
end

-- Остановка цикла Noclip
local function stopNoclipLoop()
    if noclipConnection then
        noclipConnection:Disconnect()
        noclipConnection = nil
    end
    removeNoclip()
end

-- Функция для включения режима полёта
local function enableFly()
    if Humanoid then
        Humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
        Humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, false)
        Humanoid.PlatformStand = true
    end
    
    -- Создаём BodyVelocity для удержания в воздухе
    local bv = Instance.new("BodyVelocity")
    bv.Name = "FlyVelocity"
    bv.MaxForce = Vector3.new(4000, 4000, 4000)
    bv.Velocity = Vector3.new(0, 0, 0)
    bv.Parent = RootPart
    
    -- Создаём BodyGyro для стабилизации
    local bg = Instance.new("BodyGyro")
    bg.Name = "FlyGyro"
    bg.MaxTorque = Vector3.new(4000, 4000, 4000)
    bg.CFrame = CFrame.new(RootPart.Position, RootPart.Position + Vector3.new(0, -1, 0))
    bg.Parent = RootPart
    
    -- Включаем Noclip если он активен
    if noclipEnabled then
        applyNoclip()
        startNoclipLoop() -- Запускаем постоянный цикл
    end
end

-- Функция для отключения режима полёта
local function disableFly()
    if Humanoid then
        Humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
        Humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
        Humanoid.PlatformStand = false
    end
    
    -- Удаляем BodyVelocity и BodyGyro
    if RootPart:FindFirstChild("FlyVelocity") then
        RootPart.FlyVelocity:Destroy()
    end
    if RootPart:FindFirstChild("FlyGyro") then
        RootPart.FlyGyro:Destroy()
    end
    
    -- Останавливаем цикл Noclip
    stopNoclipLoop()
end

-- Функция для обновления положения во время полёта
local function updateFlyPosition(targetPos)
    if not isFlying then return end
    
    local bv = RootPart:FindFirstChild("FlyVelocity")
    if bv then
        local direction = (targetPos - RootPart.Position)
        local distance = direction.Magnitude
        
        if distance > 1 then
            local speed = flySpeed
            local velocity = direction.Unit * math.min(speed, distance * 2)
            bv.Velocity = velocity
        else
            bv.Velocity = Vector3.new(0, 0, 0)
            RootPart.Position = targetPos
        end
    end
    
    -- Держим персонажа строго вертикально
    local bg = RootPart:FindFirstChild("FlyGyro")
    if bg then
        bg.CFrame = CFrame.new(RootPart.Position, RootPart.Position + Vector3.new(0, -1, 0))
    end
end

-- Функция для переключения Noclip
local function toggleNoclip()
    noclipEnabled = not noclipEnabled
    
    if noclipEnabled then
        noclipButton.Text = "✅ Noclip: Вкл"
        noclipButton.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
        if isFlying then
            applyNoclip()
            startNoclipLoop()
        end
    else
        noclipButton.Text = "❌ Noclip: Выкл"
        noclipButton.BackgroundColor3 = Color3.fromRGB(200, 80, 80)
        if isFlying then
            stopNoclipLoop()
        end
    end
end

