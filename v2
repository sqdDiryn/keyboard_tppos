    settingsCorner.Parent = settingsFrame
    
    -- Заголовок настроек
    local settingsTitle = Instance.new("TextLabel")
    settingsTitle.Parent = settingsFrame
    settingsTitle.Size = UDim2.new(1, 0, 0, 35)
    settingsTitle.Position = UDim2.new(0, 0, 0, 0)
