-- Функция для создания кнопки с иконкой
local function createIconButton(parent, text, color, size, position)
    local btn = Instance.new("TextButton")
    btn.Parent = parent
    btn.Size = size or UDim2.new(0, 30, 0, 30)
    btn.Position = position or UDim2.new(0, 0, 0, 0)
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextSize = 18
    btn.BackgroundColor3 = color or Color3.fromRGB(50, 50, 70)
    btn.BackgroundTransparency = 0.3
    btn.Font = Enum.Font.GothamBold
    btn.BorderSizePixel = 1
    btn.BorderColor3 = Color3.fromRGB(80, 80, 100)
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 5)
    corner.Parent = btn
    
    return btn
end

