-- Основной цикл полёта
local function startFarming()
    if isFlying then return end
    
    isFlying = true
    currentWaypointIndex = 1
    
    startButton.Text = "⏹ Стоп"
    startButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    statusLabel.Text = "Статус: Летим..."
    statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    
    -- Включаем режим полёта
    enableFly()
    
    -- Запускаем цикл полёта
    task.spawn(function()
        while isFlying do
            local target = waypoints[currentWaypointIndex]
            local isLastPoint = (currentWaypointIndex == #waypoints)
            
            -- Обновляем информацию
            infoLabel.Text = "Точка: " .. currentWaypointIndex .. "/" .. #waypoints
            local progress = (currentWaypointIndex - 1) / #waypoints
            progressBar.Size = UDim2.new(progress, 0, 1, 0)
            
            if isLastPoint then
                statusLabel.Text = "🎯 Летим к финальной точке " .. currentWaypointIndex
                statusLabel.TextColor3 = Color3.fromRGB(255, 200, 50)
            else
                statusLabel.Text = "Летим к точке " .. currentWaypointIndex
                statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
            end
            
            -- Летим к точке
            local startPos = RootPart.Position
            local distance = (target - startPos).Magnitude
            
            while distance > 2 and isFlying do
                updateFlyPosition(target)
                task.wait(0.05)
                distance = (target - RootPart.Position).Magnitude
            end
            
            -- Фиксируем позицию
            if isFlying then
                RootPart.Position = target
            end
            
            -- Если это последняя точка, начинаем падение
            if isLastPoint and isFlying then
                statusLabel.Text = "💫 Достигнута финальная точка! Падение..."
                statusLabel.TextColor3 = Color3.fromRGB(255, 150, 50)
                wait(0.5)
                
                -- Отключаем режим полёта - персонаж падает
                disableFly()
                
                -- Ждём 5 секунд
                statusLabel.Text = "⏳ Ожидание 5 секунд..."
                statusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
                wait(5)
                
                if isFlying then
                    -- Телепортируем на точку 1 для нового цикла
                    statusLabel.Text = "⬆ Подъём на точку 1..."
                    statusLabel.TextColor3 = Color3.fromRGB(100, 200, 255)
                    
                    -- Включаем режим полёта для подъёма
                    enableFly()
                    
                    -- Летим на первую точку
                    local targetPos = waypoints[1]
                    local startPos2 = RootPart.Position
                    local distance2 = (targetPos - startPos2).Magnitude
                    
                    while distance2 > 2 and isFlying do
                        updateFlyPosition(targetPos)
                        task.wait(0.05)
                        distance2 = (targetPos - RootPart.Position).Magnitude
                    end
                    
                    if isFlying then
                        RootPart.Position = targetPos
                    end
                    
                    -- Сбрасываем индекс на 1
                    currentWaypointIndex = 1
                    statusLabel.Text = "🔄 Новый цикл!"
                    statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
                    wait(0.5)
                end
            else
                -- Переходим к следующей точке БЕЗ ПАУЗЫ
                if isFlying then
                    currentWaypointIndex = currentWaypointIndex + 1
                    
                    if currentWaypointIndex > #waypoints then
                        currentWaypointIndex = 1
                    end
                end
            end
        end
    end)
end

-- Функция остановки полёта
local function stopFarming()
