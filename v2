    titleCorner.Parent = settingsTitle
    
    -- Кнопка закрытия настроек
    local closeSettingsBtn = Instance.new("TextButton")
    closeSettingsBtn.Parent = settingsFrame
    closeSettingsBtn.Size = UDim2.new(0, 25, 0, 25)
    closeSettingsBtn.Position = UDim2.new(1, -30, 0, 5)
    closeSettingsBtn.Text = "✕"
    closeSettingsBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    closeSettingsBtn.TextSize = 14
    closeSettingsBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    closeSettingsBtn.BackgroundTransparency = 0.7
    closeSettingsBtn.Font = Enum.Font.GothamBold
    closeSettingsBtn.BorderSizePixel = 0
    
    closeSettingsBtn.MouseButton1Click:Connect(function()
        toggleSettings()
    end)
    
    -- Контейнер для настроек
    local scrollSettings = Instance.new("ScrollingFrame")
    scrollSettings.Parent = settingsFrame
    scrollSettings.Size = UDim2.new(1, 0, 1, -45)
    scrollSettings.Position = UDim2.new(0, 0, 0, 40)
    scrollSettings.BackgroundTransparency = 1
    scrollSettings.ScrollBarThickness = 6
    
    local settingsContainer = Instance.new("Frame")
    settingsContainer.Parent = scrollSettings
    settingsContainer.Size = UDim2.new(1, 0, 0, 0)
    settingsContainer.BackgroundTransparency = 1
    
    local yOffset = 10
    
    -- Функция создания строки настройки
    local function addSetting(labelText, controlType, defaultValue, callback)
        local rowFrame = Instance.new("Frame")
        rowFrame.Parent = settingsContainer
        rowFrame.Size = UDim2.new(1, -20, 0, 40)
        rowFrame.Position = UDim2.new(0, 10, 0, yOffset)
        rowFrame.BackgroundTransparency = 1
        rowFrame.Name = "SettingRow"
        
        local label = Instance.new("TextLabel")
        label.Parent = rowFrame
        label.Size = UDim2.new(0.5, 0, 1, 0)
        label.Position = UDim2.new(0, 0, 0, 0)
        label.BackgroundTransparency = 1
        label.Text = labelText
        label.TextColor3 = Color3.fromRGB(220, 220, 220)
        label.TextSize = 13
        label.Font = Enum.Font.Gotham
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.TextWrapped = true
        
        local control = nil
        
        if controlType == "slider" then
            -- Слайдер для интервала
            local sliderFrame = Instance.new("Frame")
            sliderFrame.Parent = rowFrame
            sliderFrame.Size = UDim2.new(0.45, 0, 0.7, 0)
            sliderFrame.Position = UDim2.new(0.52, 0, 0.15, 0)
            sliderFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
            sliderFrame.BackgroundTransparency = 0.5
            sliderFrame.BorderSizePixel = 1
            sliderFrame.BorderColor3 = Color3.fromRGB(60, 60, 80)
            sliderFrame.Name = "SliderFrame"
            
            local sliderCorner = Instance.new("UICorner")
            sliderCorner.CornerRadius = UDim.new(0, 4)
            sliderCorner.Parent = sliderFrame
            
            local fill = Instance.new("Frame")
            fill.Parent = sliderFrame
            fill.Size = UDim2.new(defaultValue / 3, 0, 1, 0)
            fill.BackgroundColor3 = Color3.fromRGB(255, 170, 0)
            fill.BackgroundTransparency = 0.5
            fill.Name = "Fill"
            
            local fillCorner = Instance.new("UICorner")
            fillCorner.CornerRadius = UDim.new(0, 4)
            fillCorner.Parent = fill
            
            local valueLabel = Instance.new("TextLabel")
            valueLabel.Parent = sliderFrame
            valueLabel.Size = UDim2.new(1, 0, 1, 0)
            valueLabel.BackgroundTransparency = 1
            valueLabel.Text = string.format("%.1fс", defaultValue)
            valueLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            valueLabel.TextSize = 12
            valueLabel.Font = Enum.Font.Gotham
            valueLabel.Name = "ValueLabel"
            
            -- Перетаскивание слайдера
            local dragging = false
            
            sliderFrame.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = true
                    local pos = input.Position.X - sliderFrame.AbsolutePosition.X
                    local width = sliderFrame.AbsoluteSize.X
                    local value = math.max(0.1, math.min(3, (pos / width) * 3))
                    fill.Size = UDim2.new(value / 3, 0, 1, 0)
                    valueLabel.Text = string.format("%.1fс", value)
                    callback(value)
                end
            end)
            
            sliderFrame.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = false
                end
            end)
            
            sliderFrame.InputChanged:Connect(function(input)
                if dragging and input.UserInputType == Enum.UserInputType.MousePosition then
                    local pos = input.Position.X - sliderFrame.AbsolutePosition.X
                    local width = sliderFrame.AbsoluteSize.X
                    local value = math.max(0.1, math.min(3, (pos / width) * 3))
                    fill.Size = UDim2.new(value / 3, 0, 1, 0)
                    valueLabel.Text = string.format("%.1fс", value)
                    callback(value)
                end
            end)
            
            control = {
                setValue = function(val)
                    fill.Size = UDim2.new(val / 3, 0, 1, 0)
                    valueLabel.Text = string.format("%.1fс", val)
                end
            }
            
        elseif controlType == "toggle" then
            -- Toggle для анти-АФК
            local toggleBtn = Instance.new("TextButton")
            toggleBtn.Parent = rowFrame
            toggleBtn.Size = UDim2.new(0.2, 0, 0.7, 0)
            toggleBtn.Position = UDim2.new(0.75, 0, 0.15, 0)
            toggleBtn.Text = defaultValue and "ON" or "OFF"
            toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            toggleBtn.TextSize = 13
            toggleBtn.BackgroundColor3 = defaultValue and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(200, 50, 50)
            toggleBtn.Font = Enum.Font.GothamBold
            toggleBtn.BorderSizePixel = 0
            toggleBtn.Name = "ToggleBtn"
            
            local toggleCorner = Instance.new("UICorner")
            toggleCorner.CornerRadius = UDim.new(0, 4)
            toggleCorner.Parent = toggleBtn
            
            local currentState = defaultValue
            
            toggleBtn.MouseButton1Click:Connect(function()
                currentState = not currentState
                toggleBtn.Text = currentState and "ON" or "OFF"
                toggleBtn.BackgroundColor3 = currentState and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(200, 50, 50)
                callback(currentState)
            end)
            
            control = {
                setValue = function(val)
                    currentState = val
                    toggleBtn.Text = val and "ON" or "OFF"
                    toggleBtn.BackgroundColor3 = val and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(200, 50, 50)
                end
            }
            
        elseif controlType == "dropdown" then
            -- Выпадающий список для клавиш
            local options = {"RightShift", "F1", "F2", "F3", "F4", "F5", "LeftShift", "LeftControl", "RightControl"}
            local dropdown = Instance.new("TextButton")
            dropdown.Parent = rowFrame
            dropdown.Size = UDim2.new(0.35, 0, 0.7, 0)
            dropdown.Position = UDim2.new(0.6, 0, 0.15, 0)
            dropdown.Text = defaultValue
            dropdown.TextColor3 = Color3.fromRGB(255, 255, 255)
            dropdown.TextSize = 13
            dropdown.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
            dropdown.Font = Enum.Font.Gotham
            dropdown.BorderSizePixel = 1
            dropdown.BorderColor3 = Color3.fromRGB(60, 60, 80)
            dropdown.Name = "DropdownBtn"
            
            local dropdownCorner = Instance.new("UICorner")
            dropdownCorner.CornerRadius = UDim.new(0, 4)
            dropdownCorner.Parent = dropdown
            
            local isOpen = false
            local listFrame = nil
            
            dropdown.MouseButton1Click:Connect(function()
                if isOpen then
                    if listFrame then listFrame:Destroy() end
                    isOpen = false
                    return
                end
                
                isOpen = true
                listFrame = Instance.new("Frame")
                listFrame.Parent = settingsContainer
                listFrame.Size = UDim2.new(0.35, 0, 0, #options * 25)
                listFrame.Position = UDim2.new(0.6, 0, 0, yOffset + 35)
                listFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 50)
                listFrame.BorderSizePixel = 1
                listFrame.BorderColor3 = Color3.fromRGB(60, 60, 80)
                listFrame.ZIndex = 10
                listFrame.Name = "DropdownList"
                
                local listCorner = Instance.new("UICorner")
                listCorner.CornerRadius = UDim.new(0, 4)
                listCorner.Parent = listFrame
                
                for i, opt in ipairs(options) do
                    local optBtn = Instance.new("TextButton")
                    optBtn.Parent = listFrame
                    optBtn.Size = UDim2.new(1, 0, 0, 25)
                    optBtn.Position = UDim2.new(0, 0, 0, (i-1) * 25)
                    optBtn.Text = opt
                    optBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
                    optBtn.TextSize = 12
                    optBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
                    optBtn.BackgroundTransparency = 0.5
                    optBtn.Font = Enum.Font.Gotham
                    optBtn.BorderSizePixel = 0
                    
                    optBtn.MouseButton1Click:Connect(function()
                        dropdown.Text = opt
                        callback(opt)
                        listFrame:Destroy()
                        isOpen = false
                    end)
                end
            end)
            
            control = {
                setValue = function(val)
                    dropdown.Text = val
                end
            }
        end
        
        yOffset = yOffset + 45
        return control
    end
    
    -- Добавляем настройки
    local intervalControl = addSetting("Интервал телепортации", "slider", settings.interval, function(val)
        settings.interval = val
        print("⚙ Interval set to: " .. val .. "s")
    end)
    
    local antiAFKControl = addSetting("Анти-АФК (Автоклик)", "toggle", settings.antiAFK, function(val)
        settings.antiAFK = val
        print("⚙ Anti-AFK: " .. (val and "ON" or "OFF"))
    end)
    
    local hotkeyControl = addSetting("Клавиша меню", "dropdown", settings.hotkey, function(val)
        settings.hotkey = val
        print("⚙ Menu hotkey set to: " .. val)
    end)
    
    -- Обновляем CanvasSize
    settingsContainer.Size = UDim2.new(1, 0, 0, yOffset + 20)
    scrollSettings.CanvasSize = UDim2.new(0, 0, 0, yOffset + 20)
end

